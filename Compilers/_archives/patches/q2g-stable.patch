--- a/gcc/config/m68k/m68080.md
+++ b/gcc/config/m68k/m68080.md
@@ -22,31 +22,85 @@
 (define_automaton "m68080_automaton")
 
 ;; model the pipelines.
-(define_cpu_unit "i0_pipeline, i1_pipeline" "m68080_automaton")
+(define_cpu_unit "m68080_i0, m68080_i1" "m68080_automaton")
 (define_cpu_unit "f0_pipeline, f1_pipeline, f2_pipeline, f3_pipeline, f4_pipeline, f5_pipeline, f6_pipeline, f7_pipeline, f8_pipeline" "m68080_automaton")
 ;;(define_cpu_unit "f_pipeline" "m68080_automaton")
 
-;; and the out ports
-(define_cpu_unit "port0, port1" "m68080_automaton")
+; The 080 can issue useful integer pairs, but both pipes share data-cache
+; access.  Keep memory as one conservative resource until the full pairing
+; table is validated against hardware counters.
+(define_cpu_unit "m68080_port0, m68080_port1" "m68080_automaton")
+(define_cpu_unit "m68080_mem" "m68080_automaton")
 
 ;; abbreviations
-(define_reservation "i_pipelines" "(i0_pipeline | i1_pipeline)")
-(define_reservation "i_ports" "(port0 | port1)")
+(define_reservation "m68080_i_any" "(m68080_i0 | m68080_i1)")
+(define_reservation "m68080_i_both" "m68080_i0 + m68080_i1")
+(define_reservation "m68080_port_any" "(m68080_port0 | m68080_port1)")
 ;;(define_reservation "f_pipelines" "(f0_pipeline | f1_pipeline| f2_pipeline| f3_pipeline| f4_pipeline| f5_pipeline| f6_pipeline| f7_pipeline| f8_pipeline)")
 ;;(define_reservation "f_pipelines" "(f_pipeline)")
 
+;; One-cycle integer instructions without data-memory access.  These are the
+;; main pairing candidates measured through IEP2.
+(define_insn_reservation "m68080_int_00" 1
+  (and (and (eq_attr "cpu" "m68080")
+	    (eq_attr "type" "alu_l,aluq_l,alux_l,bfext,bitr,bitrw,
+                             clr,clr_l,cmp,cmp_l,ext,
+                             mov3q_l,move,move_l,moveq_l,mvsz,neg_l,
+                             scc,shift,tst,tst_l"))
+       (eq_attr "op_mem" "00"))
+  "m68080_i_any + m68080_port_any")
 
-;; simple insns with 1 cycle
-(define_insn_reservation "simple" 1 (eq_attr "type" "alu_l")
-"i_pipelines, i_ports")
+;; LEA is not a data-cache access and paired well in the counter tests.
+(define_insn_reservation "m68080_lea" 1
+  (and (eq_attr "cpu" "m68080")
+       (eq_attr "type" "lea"))
+  "m68080_i_any + m68080_port_any")
+
+(define_insn_reservation "m68080_branch" 1
+  (and (eq_attr "cpu" "m68080")
+       (eq_attr "type" "bcc,bra,bsr,jmp,jsr,rts"))
+  "m68080_i_any + m68080_port_any")
+
+;; Single data-memory access.  A load/store can still pair with a non-memory
+;; integer instruction, but not with another memory operation.
+(define_insn_reservation "m68080_mem_read" 1
+  (and (and (eq_attr "cpu" "m68080")
+	    (eq_attr "type" "alu_l,aluq_l,alux_l,bfext,bitr,bitrw,
+                             clr,clr_l,cmp,cmp_l,ext,
+                             mov3q_l,move,move_l,moveq_l,mvsz,neg_l,
+                             scc,shift,tst,tst_l"))
+       (eq_attr "op_mem" "10,i0"))
+  "m68080_i_any + m68080_port_any + m68080_mem")
 
-;; mul takes 2 cycles
-(define_insn_reservation "mul" 2 (eq_attr "type" "mul_w,mul_l")
-"(i0_pipeline*2 | i1_pipeline*2), i_ports")
+(define_insn_reservation "m68080_mem_write" 1
+  (and (and (eq_attr "cpu" "m68080")
+	    (eq_attr "type" "alu_l,aluq_l,alux_l,bfext,bitr,bitrw,
+                             clr,clr_l,cmp,cmp_l,ext,
+                             mov3q_l,move,move_l,moveq_l,mvsz,neg_l,
+                             scc,shift"))
+       (eq_attr "op_mem" "01,0i"))
+  "m68080_i_any + m68080_port_any + m68080_mem")
 
-;; div takes 2 cycles
-;;(define_insn_reservation "div" 32 (eq_attr "type" "div_l")
-;;"(i0_pipeline*32 | i1_pipeline*32), i_ports")
+(define_insn_reservation "m68080_mem_readwrite" 3
+  (and (and (eq_attr "cpu" "m68080")
+	    (eq_attr "type" "alu_l,aluq_l,alux_l,bfext,bitr,bitrw,
+                             clr,clr_l,cmp,cmp_l,ext,
+                             mov3q_l,move,move_l,moveq_l,mvsz,neg_l,
+                             scc,shift"))
+       (eq_attr "op_mem" "11,i1,1i"))
+  "m68080_i_any + m68080_port_any + m68080_mem*2")
+
+;; Keep multiply/divide conservative for v1.  They did not belong to the
+;; strong pairing candidates in the current hardware-counter tests.
+(define_insn_reservation "m68080_muldiv" 4
+  (and (eq_attr "cpu" "m68080")
+       (eq_attr "type" "mul_w,mul_l,div_w,div_l"))
+  "m68080_i_both*4 + m68080_port0 + m68080_port1")
+
+(define_insn_reservation "m68080_other" 2
+  (and (eq_attr "cpu" "m68080")
+       (eq_attr "type" "link,pea,trap,unlk,unknown"))
+  "m68080_i_both + m68080_port0 + m68080_port1")
 
 ;; all insns with latency 9
 (define_insn_reservation "m68080_fpu_9" 9
