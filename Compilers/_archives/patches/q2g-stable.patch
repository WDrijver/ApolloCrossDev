 /* Generate a macro of the form __mPREFIX_cpu_NAME, where PREFIX is the
@@ -2084,6 +2097,23 @@ output_btst (rtx *operands, rtx countop, rtx dataop, rtx_insn *insn, int signpos
 /* Return true if X is a legitimate base register.  STRICT_P says
    whether we need strict checking.  */
 
+/* Return true if X contains an RTL register known to carry a pointer.
+   The 68080 LEA guard uses this to keep legitimate pre-reload
+   object/pointer address arithmetic recognizable while still avoiding
+   LEA for pure integer math.  */
+
+bool
+m68k_contains_pointer_reg_p (rtx x)
+{
+  subrtx_iterator::array_type array;
+
+  FOR_EACH_SUBRTX (iter, array, x, ALL)
+    if (REG_P (*iter) && REG_POINTER (*iter))
+      return true;
+
+  return false;
+}
+
 bool
 m68k_legitimate_base_reg_p (rtx x, bool strict_p)
 {
@@ -6786,9 +6816,11 @@ m68k_sched_issue_rate (void)
     case CPU_CFV1:
     case CPU_CFV2:
     case CPU_CFV3:
-    case CPU_M68080:
       return 1;
 
+    case CPU_M68080:
+      return 2;
+
     case CPU_CFV4:
       return 2;
 
