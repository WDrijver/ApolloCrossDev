 	m68k_sched_mac = MAC_NO;
     }
+
+  if (m68k_sched_cpu == CPU_M68080)
+    {
+      flag_schedule_speculative = 0;
+      flag_schedule_speculative_load = 0;
+      flag_schedule_speculative_load_dangerous = 0;
+    }
 }
 
 /* Implement TARGET_OVERRIDE_OPTIONS_AFTER_CHANGE.  */
@@ -806,6 +813,12 @@ m68k_override_options_after_change (void)
       flag_modulo_sched = 0;
       flag_live_range_shrinkage = 0;
     }
+  else if (m68k_sched_cpu == CPU_M68080)
+    {
+      flag_schedule_speculative = 0;
+      flag_schedule_speculative_load = 0;
+      flag_schedule_speculative_load_dangerous = 0;
+    }
 }
 
 /* Generate a macro of the form __mPREFIX_cpu_NAME, where PREFIX is the
@@ -6840,9 +6853,11 @@ m68k_sched_issue_rate (void)
     case CPU_CFV1:
     case CPU_CFV2:
     case CPU_CFV3:
-    case CPU_M68080:
       return 1;
 
+    case CPU_M68080:
+      return 2;
+
     case CPU_CFV4:
       return 2;
 
@@ -7843,4 +7858,4 @@ m68k_select_section (tree decl, int reloc ATTRIBUTE_UNUSED,
   return default_select_section (decl, reloc, align);
 }
 
-#include "gt-m68k.h"
\ No newline at end of file
+#include "gt-m68k.h"
diff --git a/gcc/gimple-ssa-split-paths.c b/gcc/gimple-ssa-split-paths.c
