+++ b/gcc/config/m68k/m68k.c
@@ -6023,6 +6023,32 @@ m68k_regno_mode_ok (int regno, machine_mode mode)
   return false;
 }
 
+/* Implement REGISTER_MOVE_COST.  */
+
+int
+m68k_register_move_cost (machine_mode mode, enum reg_class class1,
+                         enum reg_class class2)
+{
+  int cost;
+
+  cost = ((((class1) == FP_REGS) != ((class2) == FP_REGS)) ? 4 : 2);
+
+  /* On 68080, address registers are still excellent address registers, but
+     hardware measurements show dense integer chains through address registers
+     are far slower than equivalent data-register chains.  Nudge IRA/reload
+     away from using A-regs as pure integer scratch registers without banning
+     legitimate pointer/address allocation.  Keep the first Q6C probe small:
+     +2 matched the earlier safer regmove experiment and should be less likely
+     to increase spills than the aggressive +4 variant.  */
+  if (TUNE_68080
+      && INTEGRAL_MODE_P (mode)
+      && ((class1 == DATA_REGS && class2 == ADDR_REGS)
+          || (class1 == ADDR_REGS && class2 == DATA_REGS)))
+    return cost + 2;
+
+  return cost;
+}
+
 /* Implement SECONDARY_RELOAD_CLASS.  */
 
